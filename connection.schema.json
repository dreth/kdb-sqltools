{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "server": {
      "title": "Host",
      "type": "string",
      "default": "localhost",
      "minLength": 1
    },
    "port": {
      "title": "Port",
      "type": "number",
      "default": 5000,
      "minimum": 1,
      "maximum": 65535
    },
    "username": {
      "title": "Username",
      "type": "string"
    },
    "password": {
      "title": "Password",
      "type": "string"
    },
    "database": {
      "title": "Namespace",
      "description": "Optional q namespace used for object explorer metadata, for example . or .analytics.",
      "type": "string",
      "default": "."
    },
    "connectionTimeout": {
      "title": "Timeout (seconds)",
      "type": "number",
      "default": 30,
      "minimum": 0
    }
  },
  "required": [
    "server",
    "port"
  ]
}
