{
  "name": "kdb-sqltools",
  "displayName": "SQLTools kdb Driver",
  "description": "SQLTools driver for kdb+/q using q IPC over TCP",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.42.0"
  },
  "publisher": "kdb-sqltools",
  "license": "MIT",
  "repository": {},
  "bugs": {},
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "test:unit": "npm run compile && node test/run.js",
    "test:e2e": "npm run compile && node test/e2e/run.js",
    "test": "npm run compile && node test/run.js && node test/e2e/run.js",
    "watch": "tsc -watch -p ./"
  },
  "keywords": [
    "kdb",
    "kdb+",
    "q",
    "sqltools-driver"
  ],
  "categories": [
    "Other"
  ],
  "extensionDependencies": [
    "mtxr.sqltools"
  ],
  "activationEvents": [
    "*",
    "onLanguage:sql",
    "onCommand:sqltools.*"
  ],
  "main": "./out/extension.js",
  "dependencies": {
    "@sqltools/base-driver": "0.2.4",
    "@sqltools/types": "0.2.1",
    "uuid": "^7.0.2"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.5.5",
    "@types/node": "^14.0.9",
    "@types/vscode": "^1.42.0",
    "@vscode/test-electron": "^3.0.0",
    "mocha": "^11.7.6",
    "typescript": "^3.7.3"
  }
}
